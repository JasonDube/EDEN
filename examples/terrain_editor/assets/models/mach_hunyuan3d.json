{
    "name": "hunyuan3d",
    "display_name": "Hunyuan3D Model Generator",
    "description": "Generates a 3D GLB model from an input image using Hunyuan3D-2",
    "inputs": [
        {"name": "image", "type": "image", "required": true}
    ],
    "params": [
        {"name": "steps", "type": "int", "default": "5"},
        {"name": "octree_resolution", "type": "int", "default": "256"},
        {"name": "max_faces", "type": "int", "default": "10000"},
        {"name": "texture", "type": "bool", "default": "true"},
        {"name": "remove_bg", "type": "bool", "default": "true"}
    ],
    "outputs": ["model"]
}
